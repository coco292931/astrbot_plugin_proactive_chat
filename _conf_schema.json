    "web_admin": {
        "description": "🌐 Web 管理端设置",
        "type": "object",
        "items": {
            "enabled": {
                "description": "✅ 启用 Web 管理端",
                "type": "bool",
                "default": true,
                "hint": "启用后会启动主动消息插件的独立 WebUI 管理端"
            },
            "host": {
                "description": "监听地址",
                "type": "string",
                "default": "127.0.0.1",
                "hint": "默认仅本机访问；如需局域网访问可改为 0.0.0.0"
            },
            "port": {
                "description": "监听端口",
                "type": "int",
                "default": 4100,
                "slider": {
                    "min": 1024,
                    "max": 65535,
                    "step": 1
                }
            },
            "password": {
                "description": "访问密码（留空则无需登录）",
                "type": "string",
                "default": "",
                "hint": "建议生产环境设置强密码"
            }
        }
    },
    "notification_settings": {
        "description": "🔔 通知系统设置",
        "type": "object",
        "items": {
            "enabled": {
                "description": "✅ 启用通知系统",
                "type": "bool",
                "default": true,
                "hint": "启用后，插件将定时从远端通知平台拉取通知并同步到 Web 管理端"
            },
            "poll_interval_seconds": {
                "description": "通知轮询间隔（秒）",
                "type": "int",
                "default": 300,
                "hint": "插件向远端通知平台轮询更新的时间间隔，最低将按 30 秒处理",
                "slider": {
                    "min": 30,
                    "max": 3600,
                    "step": 10
                }
            }
        }
    },
    "telemetry_config": {
        "description": "📡 遥测设置",
        "type": "object",
        "items": {
            "enabled": {
                "description": "✅ 启用匿名遥测",
                "type": "bool",
                "default": true,
                "hint": "启用后，插件会匿名上报配置统计与错误信息，用于帮助改进插件。不会上报会话列表、提示词和密码等敏感信息"
            }
        }
    }
}
